---
import { Picture, getImage } from "astro:assets";

import BaseLayout from "@layouts/BaseLayout.astro";
import Banner from "@components/Banner/Banner.astro";
import GalleryPage from "@components/Gallery/GalleryPage.astro";

import landingImage from "@assets/images/landing.jpg"; // <-- THE PATH TO THE ASSET YOU WANT TO PRELOAD - The asset must live in src
const optimizedImage = await getImage({ src: landingImage, format: "webp" });
---

<BaseLayout
  title="Before & After Gallery | Pristine Patio Pros Jacksonville FL"
  description="See our pressure washing results! Browse before and after photos of driveways, patios, and homes in Jacksonville, FL. Quality exterior cleaning services."
>
  <Banner title="Gallery" image={optimizedImage} />
  <GalleryPage />
</BaseLayout>
